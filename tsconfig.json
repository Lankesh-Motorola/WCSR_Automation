{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "playwright.config.ts",
    "tests/**/*.ts",
    "src/**/*.ts"
  ]
}
